# Copy this to .env.prod and fill in all values before deploying

# Database — must match POSTGRES_USER/PASSWORD/DB in docker-compose.prod.yml
DATABASE_URL=postgresql://ledgr:CHANGE_ME@db:5432/ledgr

# Redis
REDIS_URL=redis://redis:6379/0

# Security — generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# First superuser created on startup
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=CHANGE_ME
FIRST_SUPERUSER_USERNAME=admin
FIRST_SUPERUSER_FULL_NAME=Administrator

# Set to your EC2 public IP (used in password reset emails)
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP
PASSWORD_RESET_PATH=/reset-password

# CORS — must include your EC2 public IP for both ports
BACKEND_CORS_ORIGINS=["http://YOUR_EC2_PUBLIC_IP", "http://YOUR_EC2_PUBLIC_IP:8000"]

# Email (Resend SMTP) — optional, needed for password reset
MAIL_FROM=
MAIL_FROM_NAME=Ledgr
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_SERVER=smtp.resend.com
MAIL_PORT=465
MAIL_STARTTLS=false
MAIL_SSL_TLS=true
MAIL_TIMEOUT=30
