# Copy to backend/.env.prod and fill in values before deploying

# RDS PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-RDS-ENDPOINT.rds.amazonaws.com:5432/budget_analyzer

# CORS — must include your CloudFront domain
BACKEND_CORS_ORIGINS=["https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net"]

# AWS Cognito — User Pool + public app client (no client secret)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_REGION=us-east-1
FIRST_SUPERUSER_EMAIL=your-email@example.com
FIRST_SUPERUSER_PASSWORD=YourSecurePassword123!
FIRST_SUPERUSER_USERNAME=admin