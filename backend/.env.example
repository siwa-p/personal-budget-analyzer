DATABASE_URL=postgresql://postgres:postgres@db:5432/budget_analyzer
REDIS_URL=redis://redis:6379/0
SECRET_KEY=                          # required: generate with `openssl rand -hex 32`
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
FIRST_SUPERUSER_EMAIL=              # required
FIRST_SUPERUSER_PASSWORD=           # required
FIRST_SUPERUSER_USERNAME=           # required
FIRST_SUPERUSER_FULL_NAME=
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_PATH=/reset-password

# Email (Resend SMTP)
MAIL_FROM=onboarding@resend.dev
MAIL_FROM_NAME=Smore Budget
MAIL_USERNAME=resend
MAIL_PASSWORD=this_must_be_your_resend_account_api_key
MAIL_SERVER=smtp.resend.com
MAIL_PORT=465
MAIL_STARTTLS=false
MAIL_SSL_TLS=true
MAIL_TIMEOUT=30
# Resend notes
# MAIL_USERNAME should be "resend"
# MAIL_PASSWORD is your Resend API key (starts with "re_")

# Optional External APIs
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

GOOGLE_CLOUD_VISION_API_KEY=
