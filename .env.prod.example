# Copy to .env before running docker-compose.prod.yml
# These are read by docker-compose for service environment

POSTGRES_USER=ledgr
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ledgr

# ECR registry base URL — used by docker-compose.prod.yml to pull backend image
# Format: ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com
ECR_BASE=YOUR_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com

# Frontend deploy targets — used by Makefile
VITE_API_URL=https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net
S3_BUCKET=your-s3-bucket-name

# EC2 SSH access — used by Makefile deploy-backend target
EC2_HOST=your-ec2-public-ip
EC2_KEY=/path/to/your-key.pem
