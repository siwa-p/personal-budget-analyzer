# Copy to .env before running docker-compose.prod.yml
# These are read by docker-compose for service environment + build args

POSTGRES_USER=ledgr
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ledgr

# Set to your EC2 public IP — baked into the frontend JS bundle at build time
VITE_API_URL=http://YOUR_EC2_PUBLIC_IP:8000
