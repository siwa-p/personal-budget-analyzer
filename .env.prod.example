# Copy to .env.prod and fill in values — used by Makefile and docker compose

# ECR registry base URL (ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com)
ECR_BASE=YOUR_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com

# Frontend env vars baked into the JS bundle at build time
VITE_API_URL=https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# S3 bucket for frontend static files
S3_BUCKET=your-s3-bucket-name

# EC2 SSH access — used by Makefile deploy-backend target
EC2_HOST=your-ec2-public-ip
EC2_KEY=/path/to/your-key.pem
